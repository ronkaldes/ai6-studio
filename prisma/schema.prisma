generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TrendSignal {
  id              String   @id @default(cuid())
  source          String
  title           String
  url             String?
  velocitySignal  String?
  opportunityScore Int     @default(0)   // 0-10
  category        String?
  aiSummary       String?
  opportunityCard String?
  pipelineStatus  String   @default("new")
  runId           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  idea            Idea?    @relation(fields: [ideaId], references: [id])
  ideaId          String?
  
  campaign        Campaign? @relation(fields: [campaignId], references: [id])
  campaignId      String?
}

model Idea {
  id              String   @id @default(cuid())
  title           String
  stage           String   @default("signal")
  ventureScore    Int?
  opportunityMemo String?
  dvfScores       String?
  assumptionMap   String?
  experiments     String?
  sourceSignalId  String?
  assigneeId      String?
  submittedBy     String?
  daysInStage     Int      @default(0)
  boardDecision   String?
  boardRationale  String?
  boardVotes      String?
  // BOI Innovation Tool outputs
  userPersonas         String?
  hmwStatements        String?
  futureScenarios      String?
  businessReinvention  String?
  aiStrategyMatrix     String?
  aiBlueprint          String?
  aiSimulation         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  signals         TrendSignal[]
}

model ProjectContext {
  id        String   @id @default(cuid())
  content   String
  version   Int      @default(1)
  stageGates String? 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BoardSession {
  id          String   @id @default(cuid())
  ideaId      String
  sessionDate DateTime @default(now())
  attendees   String?
  decision    String
  votes       String
  learnings   String?
  createdAt   DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("member")
  createdAt DateTime @default(now())
}

model Learning {
  id          String   @id @default(cuid())
  ideaId      String
  ideaTitle   String
  category    String?
  killReason  String?
  keySentence String
  tags        String[]
  createdAt   DateTime @default(now())
}

model SprintRetrospective {
  id                     String   @id @default(cuid())
  ideaId                 String   @unique
  hypothesisValidated    String
  actualOutcome          String
  ventureScoreAccuracy   Int
  materializedKillRisks  String[]
  keyLearning            String?
  wouldBuildAgain        String
  createdAt              DateTime @default(now())
}


model Comment {
  id         String   @id @default(cuid())
  ideaId     String
  authorName String   @default("Anonymous")
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ideaId, createdAt])
}

model IdeaVote {
  id        String   @id @default(cuid())
  ideaId    String
  userName  String   @default("Anonymous")
  vote      Int      // 1 (up) or -1 (down)
  createdAt DateTime @default(now())

  @@unique([ideaId, userName])
  @@index([ideaId])
}

model FutureScenarioRun {
  id          String   @id @default(cuid())
  year        Int
  industry    String
  sector      String
  scenarios   String
  ideaId      String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Campaign {
  id              String   @id @default(cuid())
  name            String
  domainFocus     String?
  minScore        Int      @default(6)
  deadline        DateTime?
  status          String   @default("active")
  summary         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  signals         TrendSignal[]
}
